NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://trello:trello@postgres:5432/trello
REDIS_URL=redis://redis:6379

JWT_SECRET=change-me-in-prod-use-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=trello

# Seeded super_admin credentials
SEED_ADMIN_EMAIL=admin@trello.local
SEED_ADMIN_PASSWORD=Admin@12345

# Frontend URL used in email links (reset password, card links)
APP_URL=http://localhost:5173

# SMTP for outbound email. Leave SMTP_HOST empty to log emails to console (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Trello Clone <no-reply@trello.local>

# Run BullMQ workers (email, due-date reminders) in this process
ENABLE_WORKERS=true
