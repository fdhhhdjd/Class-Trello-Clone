{
  "name": "trello-clone-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted Trello clone backend (Express + Prisma, ESM JavaScript)",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch --import ./src/observability/tracing.js src/index.js",
    "start": "node --import ./src/observability/tracing.js src/index.js",
    "seed": "node src/db/seed.js",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:generate": "prisma generate"
  },
  "prisma": {
    "seed": "node src/db/seed.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.2",
    "nodemailer": "^8.0.10",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=20"
  }
}
