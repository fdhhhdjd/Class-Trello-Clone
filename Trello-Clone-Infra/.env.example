# Copy to .env: cp .env.example .env

NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://trello:trello@postgres:5432/trello
REDIS_URL=redis://redis:6379

JWT_SECRET=changeme-dev-secret

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=trello
# Browser-reachable MinIO URL (presign host + public file URLs). Set to your host IP/domain.
MINIO_PUBLIC_URL=http://localhost:9000

# Prod: set false so the one-time super-admin setup page appears (Dev: true)
SEED_SUPER_ADMIN=true
