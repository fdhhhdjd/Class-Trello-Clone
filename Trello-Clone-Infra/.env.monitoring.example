# Observability env — APPEND these to the existing .env on the VPS (same file the
# api/postgres services read). Do NOT commit the real .env.

# --- Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-strong

# --- API tracing (read by the api container) ---
# Point the app's OpenTelemetry exporter at Tempo. Empty/unset = tracing disabled.
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
SERVICE_VERSION=1.0.0
LOG_LEVEL=info

# --- Telegram alerts (used to fill monitoring/alertmanager.yml on the server) ---
# Create a bot via @BotFather, get chat_id via @userinfobot. SEPARATE bot for dev vs prod.
TELEGRAM_BOT_TOKEN=123456:ABC-yourbottoken
TELEGRAM_CHAT_ID=123456789

# Note: postgres_exporter/redis_exporter reuse POSTGRES_USER/POSTGRES_PASSWORD/
# POSTGRES_DB already defined in .env.
