{
  "uid": "trello-api-red",
  "title": "Trello API — RED + SLO",
  "tags": ["trello", "api", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Request rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_requests_total{job=\"trello_api\"}[5m])) by (route)", "legendFormat": "{{route}}" }
      ]
    },
    {
      "id": 2, "type": "timeseries", "title": "Error rate % (5xx)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_requests_total{job=\"trello_api\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"trello_api\"}[5m]))", "legendFormat": "5xx ratio" }
      ]
    },
    {
      "id": 3, "type": "timeseries", "title": "Latency p50 / p95 / p99 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"trello_api\"}[5m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"trello_api\"}[5m])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"trello_api\"}[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 4, "type": "timeseries", "title": "In-flight requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(http_requests_in_flight{job=\"trello_api\"})", "legendFormat": "in-flight" }
      ]
    },
    {
      "id": 5, "type": "stat", "title": "Availability (30d) — SLO 99.9%",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.995 },
            { "color": "green", "value": 0.999 }
          ] }
        }, "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_requests_total{job=\"trello_api\",status_code!~\"5..\"}[30d])) / sum(rate(http_requests_total{job=\"trello_api\"}[30d]))" }
      ]
    },
    {
      "id": 6, "type": "stat", "title": "Error budget burn (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 6 },
            { "color": "red", "value": 14.4 }
          ] }
        }, "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "job:slo_error_ratio:rate1h / 0.001" }
      ]
    },
    {
      "id": 7, "type": "stat", "title": "p95 vs target (500ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.5 }
          ] }
        }, "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"trello_api\"}[5m])) by (le))" }
      ]
    }
  ]
}
